generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trainer {
  id        String  @unique   @id   @default(uuid())
  email     String  @unique
  name      String?
  password  String
  projects_trainer   Project[] @relation("TrainerProjects")
  project_admin     Project[]
  quiz_creators     Quiz[] @relation("QuizCreators")
  course_creators   Course[] @relation("CourseCreators")
  resources     Resource[]
}

model Trainee {
  id        String  @unique   @id     @default(uuid())
  phone     String  @unique
  name      String?
  chats       Chat[]
  projects_trainee   Project[] @relation("TraineeProjects")
}

model Project {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  trainers    Trainer[] @relation("TrainerProjects")
  trainees    Trainee[]  @relation("TraineeProjects")
  adminId      String
  admin        Trainer @relation(fields: [adminId], references: [id])
  quizes       Quiz[]
  courses      Course[]
  resources    Resource[]
  chats       Chat[]
  contents     ProjectContent[]
  createdAt    DateTime @default(now())
}

model Quiz {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  published   Boolean @default(false)
  creators      Trainer[] @relation("QuizCreators")
  content       ProjectContent?
  sections    Section[]
  createdAt    DateTime @default(now())
}

model Course {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  published   Boolean @default(false)
  creators      Trainer[] @relation("CourseCreators")
  content       ProjectContent?
  createdAt    DateTime @default(now())
}

model ProjectContent {
  id          String  @unique   @id   @default(uuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  type        ContentType
  quizId      String?   @unique
  quiz        Quiz?     @relation(fields: [quizId], references: [id])
  courseId     String?   @unique
  course      Course?   @relation(fields: [courseId], references: [id])
  position    Int

  @@unique([projectId, position])
  @@index([projectId])
}

enum ContentType {
  QUIZ
  COURSE
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Resource {
  id          String  @unique   @id   @default(uuid())
  refId       String
  filename    String
  url         String
  projectId   String
  project      Project @relation(fields: [projectId], references: [id])
  mimeType    String         @default("application/pdf")
  size        Int            // file size in bytes
  uploadedBy  String
  uploader    Trainer        @relation(fields: [uploadedBy], references: [id])
  status      ResourceStatus @default(PROCESSING)
  sources     Source[]
  createdAt    DateTime @default(now())
  errorMsg    String?        // store error if FAILED

  @@index([projectId])
}

enum ResourceStatus {
  PROCESSED
  PROCESSING
  FAILED
}

model Chat {
  id          String    @id @default(uuid())
  title       String?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  traineeId   String
  trainee     Trainee   @relation(fields: [traineeId], references: [id])
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId, traineeId])
}

model Message {
  id          String      @id @default(uuid())
  chatId      String
  chat        Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        MessageRole
  content     String
  sources     Source[]
  createdAt   DateTime    @default(now())
}

model Source {
  id          String   @id @default(uuid())
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id])
  filename    String
  url         String
  chunkText   String   // the relevant chunk that was used
  score       Float    // relevance score from Qdrant

  @@index([messageId])
}

enum MessageRole {
  USER
  ASSISTANT
}

// ─── Section ─────────────────────────────────
model Section {
  id          String     @id @default(cuid())
  quizId      String
  quiz        Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int        // 0-based position within the quiz
  questions   Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizId, order])
  @@index([quizId, order])
}

// ─── Question ────────────────────────────────
model Question {
  id        String       @id @default(cuid())
  sectionId String
  section   Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type      QuestionType
  question  String
  points    Int          @default(0)
  order     Int          // 0-based position within the section
  data      Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, order])
  @@index([sectionId, order])
}

enum QuestionType {
  mcq
  fill_ups
  true_false
  long_answer
  content_block
}