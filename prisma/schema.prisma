generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trainer {
  id        String  @unique   @id   @default(uuid())
  email     String  @unique
  name      String?
  password  String
  projects_trainer   Project[] @relation("TrainerProjects")
  project_admin     Project[]
  quiz_creators     Quiz[] @relation("QuizCreators")
  course_creators   Course[] @relation("CourseCreators")
}

model Trainee {
  id        String  @unique   @id     @default(uuid())
  phone     String  @unique
  name      String?
  projects_trainee   Project[] @relation("TraineeProjects")
}

model Project {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  trainers    Trainer[] @relation("TrainerProjects")
  trainees    Trainee[]  @relation("TraineeProjects")
  adminId      String
  admin        Trainer @relation(fields: [adminId], references: [id])
  quizes       Quiz[]
  courses      Course[]
  contents     ProjectContent[]
  createdAt    DateTime @default(now())
}

model Quiz {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  published   Boolean @default(false)
  creators      Trainer[] @relation("QuizCreators")
  content       ProjectContent?
  createdAt    DateTime @default(now())
}

model Course {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  published   Boolean @default(false)
  creators      Trainer[] @relation("CourseCreators")
  content       ProjectContent?
  createdAt    DateTime @default(now())
}

model ProjectContent {
  id          String  @unique   @id   @default(uuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  type        ContentType
  quizId      String?   @unique
  quiz        Quiz?     @relation(fields: [quizId], references: [id])
  courseId     String?   @unique
  course      Course?   @relation(fields: [courseId], references: [id])
  position    Int

  @@unique([projectId, position])
  @@index([projectId])
}

enum ContentType {
  QUIZ
  COURSE
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}