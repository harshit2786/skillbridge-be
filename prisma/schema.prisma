generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trainer {
  id        String  @unique   @id   @default(uuid())
  email     String  @unique
  name      String?
  password  String
  projects_trainer   Project[] @relation("TrainerProjects")
  project_admin     Project[]
  quiz_creators     Quiz[] @relation("QuizCreators")
  course_creators   Course[] @relation("CourseCreators")
  resources     Resource[]
}

model Trainee {
  id        String  @unique   @id     @default(uuid())
  phone     String  @unique
  name      String?
  chats       Chat[]
  progresses   TraineeProgress[]
  projects_trainee   Project[] @relation("TraineeProjects")
}

model Project {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  trainers    Trainer[] @relation("TrainerProjects")
  trainees    Trainee[]  @relation("TraineeProjects")
  adminId      String
  admin        Trainer @relation(fields: [adminId], references: [id])
  quizes       Quiz[]
  courses      Course[]
  resources    Resource[]
  chats       Chat[]
  traineeProgresses TraineeProgress[]
  contents     ProjectContent[]
  createdAt    DateTime @default(now())
}

model Quiz {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  published   Boolean @default(false)
  creators      Trainer[] @relation("QuizCreators")
  content       ProjectContent?
  sections    QuizSection[]
  attempts QuizAttempt[]
  passingPercent     Int        @default(0) // minimum points required to pass
  createdAt    DateTime @default(now())
}

model Course {
  id          String  @unique   @id   @default(uuid())
  name        String
  description String?
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  published   Boolean @default(false)
  creators      Trainer[] @relation("CourseCreators")
  content       ProjectContent?
  sections    CourseSection[]
  courseProgresses CourseProgress[]
  createdAt    DateTime @default(now())
}

model ProjectContent {
  id          String  @unique   @id   @default(uuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id])
  type        ContentType
  quizId      String?   @unique
  quiz        Quiz?     @relation(fields: [quizId], references: [id])
  courseId     String?   @unique
  course      Course?   @relation(fields: [courseId], references: [id])
  traineeProgresses TraineeProgress[] // back-relation for currentContent
  position    Int

  @@unique([projectId, position])
  @@index([projectId])
}

enum ContentType {
  QUIZ
  COURSE
}

model Otp {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model Resource {
  id          String  @unique   @id   @default(uuid())
  refId       String
  filename    String
  url         String
  projectId   String
  project      Project @relation(fields: [projectId], references: [id])
  mimeType    String         @default("application/pdf")
  size        Int            // file size in bytes
  uploadedBy  String
  uploader    Trainer        @relation(fields: [uploadedBy], references: [id])
  status      ResourceStatus @default(PROCESSING)
  sources     Source[]
  createdAt    DateTime @default(now())
  errorMsg    String?        // store error if FAILED

  @@index([projectId])
}

enum ResourceStatus {
  PROCESSED
  PROCESSING
  FAILED
}

model Chat {
  id          String    @id @default(uuid())
  title       String?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  traineeId   String
  trainee     Trainee   @relation(fields: [traineeId], references: [id])
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId, traineeId])
}

model Message {
  id          String      @id @default(uuid())
  chatId      String
  chat        Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role        MessageRole
  content     String
  sources     Source[]
  createdAt   DateTime    @default(now())
}

model Source {
  id          String   @id @default(uuid())
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id])
  filename    String
  url         String
  chunkText   String   // the relevant chunk that was used
  score       Float    // relevance score from Qdrant

  @@index([messageId])
}

enum MessageRole {
  USER
  ASSISTANT
}

// ─── QuizSection ─────────────────────────────────
model QuizSection {
  id          String     @id @default(cuid())
  quizId      String
  quiz        Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int        // 0-based position within the quiz
  questions   Question[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizId, order])
  @@index([quizId, order])
}

// ─── Question ────────────────────────────────
model Question {
  id        String       @id @default(cuid())
  sectionId String
  section   QuizSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type      QuestionType
  question  String
  points    Int          @default(0)
  order     Int          // 0-based position within the section
  data      Json
  responses QuizQuestionResponse[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, order])
  @@index([sectionId, order])
}

enum QuestionType {
  mcq
  fill_ups
  true_false
  long_answer
  content_block
}

// ─── CourseSection ─────────────────────────────────
model CourseSection {
  id          String     @id @default(cuid())
  courseId    String
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int
  questions   CourseQuestion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, order])
  @@index([courseId, order])
}

// ─── CourseQuestion ────────────────────────────────
model CourseQuestion {
  id        String       @id @default(cuid())
  sectionId String
  section   CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  type      QuestionType
  question  String
  points    Int          @default(0)
  order     Int
  data      Json
completions CourseQuestionCompletion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, order])
  @@index([sectionId, order])
}

// ─── Trainee's overall progress on a project's content ───────────
model TraineeProgress {
  id          String   @id @default(uuid())
  traineeId   String
  trainee     Trainee  @relation(fields: [traineeId], references: [id])
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])

  // Which ProjectContent item the trainee is currently on
  // (i.e., the furthest unlocked content position)
  currentContentId String?
  currentContent   ProjectContent? @relation(fields: [currentContentId], references: [id])

  courseProgresses CourseProgress[]
  quizAttempts     QuizAttempt[]

  startedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([traineeId, projectId])
  @@index([traineeId, projectId])
}

// ─── Course Progress ─────────────────────────────────
// Tracks a trainee's progress through a specific course
model CourseProgress {
  id                String           @id @default(uuid())
  traineeProgressId String
  traineeProgress   TraineeProgress  @relation(fields: [traineeProgressId], references: [id], onDelete: Cascade)
  courseId           String
  course             Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)

  // Which section the trainee is currently on (furthest unlocked)
  currentSectionOrder Int            @default(0)

  status             CourseStatus    @default(IN_PROGRESS)
  completions        CourseQuestionCompletion[]

  startedAt          DateTime        @default(now())
  completedAt        DateTime?
  updatedAt          DateTime        @updatedAt

  @@unique([traineeProgressId, courseId])
  @@index([traineeProgressId])
}

enum CourseStatus {
  IN_PROGRESS
  COMPLETED
}

// ─── Course Question Completion ──────────────────────
// Only records that a question was answered correctly (no response stored)
model CourseQuestionCompletion {
  id               String          @id @default(uuid())
  courseProgressId  String
  courseProgress    CourseProgress  @relation(fields: [courseProgressId], references: [id], onDelete: Cascade)
  courseQuestionId  String
  courseQuestion    CourseQuestion  @relation(fields: [courseQuestionId], references: [id], onDelete: Cascade)

  // No response field — we only record completion
  completedAt      DateTime        @default(now())

  @@unique([courseProgressId, courseQuestionId])
  @@index([courseProgressId])
}

// ─── Quiz Attempt ────────────────────────────────────
// One attempt at a quiz by a trainee
// Update QuizAttempt — add feedback field
model QuizAttempt {
  id                String           @id @default(uuid())
  traineeProgressId String
  traineeProgress   TraineeProgress  @relation(fields: [traineeProgressId], references: [id], onDelete: Cascade)
  quizId            String
  quiz              Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)

  currentSectionOrder Int            @default(0)

  status            QuizAttemptStatus @default(IN_PROGRESS)
  responses         QuizQuestionResponse[]

  totalScore        Int?
  maxScore          Int?
  passed            Boolean?
  feedback          String?          // Overall quiz feedback (generated by AI later)

  startedAt         DateTime         @default(now())
  submittedAt       DateTime?
  gradedAt          DateTime?        // When grading completed
  updatedAt         DateTime         @updatedAt

  @@unique([traineeProgressId, quizId])
  @@index([traineeProgressId])
}


enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

// ─── Quiz Question Response ──────────────────────────
// Stores the trainee's actual response to each quiz question (locked after submit)
model QuizQuestionResponse {
  id             String                @id @default(uuid())
  quizAttemptId  String
  quizAttempt    QuizAttempt           @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  questionId     String
  question       Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)

  response       Json
  submitted      Boolean               @default(false)

  pointsAwarded  Int?
  maxPoints      Int?                  // Store max points for easy reference
  feedback       String?               // Per-question feedback (AI-generated for long_answer)
  gradingStatus  ResponseGradingStatus @default(PENDING)

  submittedAt    DateTime              @default(now())

  @@unique([quizAttemptId, questionId])
  @@index([quizAttemptId])
}

enum ResponseGradingStatus {
  PENDING
  AUTO_GRADED
  AI_GRADED
  MANUALLY_GRADED
}