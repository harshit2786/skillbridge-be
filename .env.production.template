# Production Environment Variables Template
# Copy this to production.env and fill in your values
# NEVER commit this file to git!

# Server Configuration
PORT=3000
NODE_ENV=production

# PostgreSQL (Supabase)
# Example: postgresql://postgres.abc123:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Redis (Upstash)
# Example: rediss://:token@host:port
REDIS_URL=

# Qdrant Cloud
# Example: https://your-cluster-id.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=
# Get this from Qdrant Cloud dashboard
QDRANT_API_KEY=

# OpenAI (Required for embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_SECRET=

# Google Cloud Storage
# Bucket name from GCS console
GCS_BUCKET_NAME=
# GCP project ID
GCS_PROJECT_ID=
# Path to service account key (deployed separately, not in env var)
GCS_KEY_FILE=

# Twilio (Optional - for trainee SMS login)
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Zoom (Optional - for video integration)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Resend (Optional - for emails)
RESEND_API_KEY=
EMAIL_FROM=

GCS_KEY_BASE64=